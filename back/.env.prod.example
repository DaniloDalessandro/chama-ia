# ===========================
# Django
# ===========================
# Gere com: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=TROQUE-PARA-UMA-CHAVE-LONGA-E-ALEATORIA
DEBUG=False
ALLOWED_HOSTS=82.25.75.110

# ===========================
# Database (PostgreSQL)
# ===========================
POSTGRES_DB=chamaia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROQUE-PARA-SENHA-FORTE
# POSTGRES_HOST e portas sao gerenciados pelo docker-compose

# ===========================
# CORS - permite o frontend acessar a API
# ===========================
CORS_ALLOWED_ORIGINS=http://82.25.75.110:3000

# ===========================
# Webhooks
# ===========================
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEBHOOK_ENCRYPTION_KEY=TROQUE-PARA-CHAVE-FERNET-GERADA

# ===========================
# xAI Grok (classificacao de chamados) - OBRIGATORIO para IA
# Chave gratuita em: https://console.x.ai (USD 25 de credito no cadastro)
# ===========================
XAI_API_KEY=sua-chave-xai-aqui
XAI_MODEL=grok-3-mini

# ===========================
# Google Gemini (embeddings / similaridade) - OPCIONAL
# ===========================
# GEMINI_API_KEY=sua-chave-gemini-aqui

# ===========================
# Email (SMTP)
# ===========================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app
DEFAULT_FROM_EMAIL=ChamaNF Suporte <suporte@chamanf.com.br>

# ===========================
# Frontend URL (para links nos e-mails)
# ===========================
FRONTEND_URL=http://82.25.75.110:3000

# ===========================
# Sentry (opcional)
# ===========================
# SENTRY_DSN=https://...
# SENTRY_ENVIRONMENT=production
